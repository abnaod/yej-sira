generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  customer
  admin

  @@map("user_role")
}

model User {
  id            String     @id
  name          String
  email         String
  emailVerified Boolean    @map("email_verified")
  image         String?
  role          UserRole   @default(customer)
  createdAt     DateTime   @map("created_at")
  updatedAt     DateTime   @map("updated_at")
  sessions      Session[]
  accounts      Account[]
  carts         Cart[]
  orders         Order[]
  favorites      Favorite[]
  productRatings ProductRating[]
  ownedShop      Shop?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @map("created_at")
  updatedAt             DateTime  @map("updated_at")

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")

  @@map("verification")
}

enum OrderStatus {
  pending
  paid
  fulfilled
  cancelled

  @@map("order_status")
}

enum ContentLocale {
  en
  am

  @@map("content_locale")
}

enum ShopStatus {
  pending
  active
  rejected
  suspended

  @@map("shop_status")
}

model Shop {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String?
  imageUrl    String?    @map("image_url")
  ownerUserId String?    @map("owner_user_id")
  owner       User?      @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  status      ShopStatus @default(pending)
  contactEmail            String? @map("contact_email")
  contactPhone            String? @map("contact_phone")
  socialLinks             Json?   @map("social_links")
  shippingPolicy          String? @map("shipping_policy") @db.Text
  returnsPolicy           String? @map("returns_policy") @db.Text
  businessLegalName       String? @map("business_legal_name")
  businessTaxId           String? @map("business_tax_id")
  businessAddressLine1    String? @map("business_address_line1")
  businessAddressLine2    String? @map("business_address_line2")
  businessCity            String? @map("business_city")
  businessPostalCode      String? @map("business_postal_code")
  businessCountry         String? @map("business_country")
  products    Product[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@unique([ownerUserId])
  @@index([status])
  @@map("shops")
}

enum CategoryAttributeInputType {
  select
  text
  number
  boolean

  @@map("category_attribute_input_type")
}

model Category {
  id           String                      @id @default(cuid())
  slug         String                      @unique
  name         String
  imageUrl     String                      @map("image_url")
  sortOrder    Int                         @default(0) @map("sort_order")
  products     Product[]
  translations CategoryTranslation[]
  attributeDefinitions CategoryAttributeDefinition[]
  createdAt    DateTime                    @default(now()) @map("created_at")
  updatedAt    DateTime                    @updatedAt @map("updated_at")

  @@map("categories")
}

model CategoryAttributeDefinition {
  id             String                                   @id @default(cuid())
  categoryId     String                                   @map("category_id")
  category       Category                                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  key            String
  inputType      CategoryAttributeInputType               @map("input_type")
  sortOrder      Int                                      @default(0) @map("sort_order")
  isRequired     Boolean                                  @default(false) @map("is_required")
  allowedValues  AttributeAllowedValue[]
  translations   CategoryAttributeDefinitionTranslation[]
  productValues  ProductAttributeValue[]

  @@unique([categoryId, key])
  @@index([categoryId])
  @@map("category_attribute_definitions")
}

model CategoryAttributeDefinitionTranslation {
  id           String                    @id @default(cuid())
  definitionId String                    @map("definition_id")
  definition   CategoryAttributeDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  locale       ContentLocale
  label        String

  @@unique([definitionId, locale])
  @@index([definitionId])
  @@map("category_attribute_definition_translations")
}

model AttributeAllowedValue {
  id            String                         @id @default(cuid())
  definitionId  String                         @map("definition_id")
  definition    CategoryAttributeDefinition    @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  key           String
  sortOrder     Int                            @default(0) @map("sort_order")
  translations  AttributeAllowedValueTranslation[]
  productValues ProductAttributeValue[]

  @@unique([definitionId, key])
  @@index([definitionId])
  @@map("attribute_allowed_values")
}

model AttributeAllowedValueTranslation {
  id             String                @id @default(cuid())
  allowedValueId String                @map("allowed_value_id")
  allowedValue   AttributeAllowedValue @relation(fields: [allowedValueId], references: [id], onDelete: Cascade)
  locale         ContentLocale
  label          String

  @@unique([allowedValueId, locale])
  @@index([allowedValueId])
  @@map("attribute_allowed_value_translations")
}

model ProductAttributeValue {
  id             String                    @id @default(cuid())
  productId      String                    @map("product_id")
  product        Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  definitionId   String                    @map("definition_id")
  definition     CategoryAttributeDefinition @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  allowedValueId String?                   @map("allowed_value_id")
  allowedValue   AttributeAllowedValue?    @relation(fields: [allowedValueId], references: [id], onDelete: Restrict)
  textValue      String?
  numberValue    Decimal?                  @db.Decimal(12, 4)
  booleanValue   Boolean?

  @@unique([productId, definitionId])
  @@index([productId])
  @@index([definitionId])
  @@index([allowedValueId])
  @@map("product_attribute_values")
}

model CategoryTranslation {
  id         String        @id @default(cuid())
  categoryId String        @map("category_id")
  category   Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale     ContentLocale
  name       String

  @@unique([categoryId, locale])
  @@index([categoryId])
  @@map("category_translations")
}

model Tag {
  id           String           @id @default(cuid())
  slug         String           @unique
  name         String
  productTags  ProductTag[]
  translations TagTranslation[]

  @@index([slug])
  @@map("tags")
}

model TagTranslation {
  id     String        @id @default(cuid())
  tagId  String        @map("tag_id")
  tag    Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)
  locale ContentLocale
  name   String

  @@unique([tagId, locale])
  @@index([tagId])
  @@map("tag_translations")
}

model Promotion {
  id           String                 @id @default(cuid())
  slug         String                 @unique
  title        String
  subtitle     String?
  badgeLabel   String                 @map("badge_label")
  startsAt     DateTime               @map("starts_at")
  endsAt       DateTime               @map("ends_at")
  heroImageUrl String?                @map("hero_image_url")
  sortOrder    Int                    @default(0) @map("sort_order")
  priority     Int                    @default(0)
  products     PromotionProduct[]
  translations PromotionTranslation[]
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  @@index([startsAt, endsAt])
  @@map("promotions")
}

model PromotionTranslation {
  id          String        @id @default(cuid())
  promotionId String        @map("promotion_id")
  promotion   Promotion     @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  locale      ContentLocale
  title       String
  subtitle    String?
  badgeLabel  String        @map("badge_label")

  @@unique([promotionId, locale])
  @@index([promotionId])
  @@map("promotion_translations")
}

model PromotionProduct {
  id          String    @id @default(cuid())
  promotionId String    @map("promotion_id")
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  productId   String    @map("product_id")
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder   Int       @default(0) @map("sort_order")

  @@unique([promotionId, productId])
  @@index([promotionId])
  @@index([productId])
  @@map("promotion_products")
}

model Product {
  id                String               @id @default(cuid())
  slug              String               @unique
  shopId            String               @map("shop_id")
  shop              Shop                 @relation(fields: [shopId], references: [id], onDelete: Restrict)
  categoryId        String               @map("category_id")
  category          Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name              String
  description       String
  rating            Decimal              @db.Decimal(3, 2)
  reviewCount       Int                  @map("review_count")
  featured          Boolean              @default(false)
  isPublished       Boolean              @default(false) @map("is_published")
  images            ProductImage[]
  variants          ProductVariant[]
  favorites         Favorite[]
  productTags       ProductTag[]
  promotionProducts PromotionProduct[]
  translations      ProductTranslation[]
  ratings           ProductRating[]
  attributeValues   ProductAttributeValue[]
  orderItems        OrderItem[]
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([shopId])
  @@map("products")
}

model ProductRating {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  stars     Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, productId])
  @@index([productId])
  @@map("product_ratings")
}

model ProductTranslation {
  id          String        @id @default(cuid())
  productId   String        @map("product_id")
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale      ContentLocale
  name        String
  description String

  @@unique([productId, locale])
  @@index([productId])
  @@map("product_translations")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("favorites")
}

model ProductTag {
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tagId     String  @map("tag_id")
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int     @default(0) @map("sort_order")

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id             String                      @id @default(cuid())
  productId      String                      @map("product_id")
  product        Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku            String?                     @unique
  label          String
  colorHex       String?                     @map("color_hex")
  price          Decimal                     @db.Decimal(10, 2)
  compareAtPrice Decimal?                    @map("compare_at_price") @db.Decimal(10, 2)
  stock          Int
  cartItems      CartItem[]
  translations   ProductVariantTranslation[]

  @@index([productId])
  @@map("product_variants")
}

model ProductVariantTranslation {
  id        String         @id @default(cuid())
  variantId String         @map("variant_id")
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  locale    ContentLocale
  label     String

  @@unique([variantId, locale])
  @@index([variantId])
  @@map("product_variant_translations")
}

model Cart {
  id             String     @id @default(cuid())
  userId         String?    @unique @map("user_id")
  user           User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousToken String?    @unique @map("anonymous_token")
  items          CartItem[]
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@map("carts")
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String         @map("cart_id")
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String         @map("variant_id")
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int

  @@unique([cartId, variantId])
  @@index([variantId])
  @@map("cart_items")
}

model Order {
  id                 String      @id @default(cuid())
  userId             String      @map("user_id")
  user               User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  status             OrderStatus @default(pending)
  subtotal           Decimal     @db.Decimal(10, 2)
  shipping           Decimal     @db.Decimal(10, 2)
  tax                Decimal     @db.Decimal(10, 2)
  total              Decimal     @db.Decimal(10, 2)
  shippingLine1      String      @map("shipping_line1")
  shippingLine2      String?     @map("shipping_line2")
  shippingCity       String      @map("shipping_city")
  shippingPostalCode String      @map("shipping_postal_code")
  shippingCountry    String      @map("shipping_country")
  items              OrderItem[]
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String   @map("order_id")
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String?  @map("product_id")
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName  String   @map("product_name")
  variantLabel String?  @map("variant_label")
  unitPrice    Decimal  @map("unit_price") @db.Decimal(10, 2)
  quantity     Int
  imageUrl     String   @map("image_url")

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}
