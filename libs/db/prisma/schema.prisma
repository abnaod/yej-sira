generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  customer
  admin

  @@map("user_role")
}

model User {
  id                     String                         @id
  name                   String
  email                  String
  phone                  String?
  emailVerified          Boolean                        @map("email_verified")
  image                  String?
  role                   UserRole                       @default(customer)
  createdAt              DateTime                       @map("created_at")
  updatedAt              DateTime                       @map("updated_at")
  sessions               Session[]
  accounts               Account[]
  carts                  Cart[]
  orders                 Order[]
  favorites              Favorite[]
  listingRatings         ListingRating[]
  ownedShop              Shop?
  buyerConversations     Conversation[]                 @relation("ConversationBuyer")
  messageSender          Message[]                      @relation("MessageSender")
  conversationReadStates ConversationParticipantState[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @map("created_at")
  updatedAt             DateTime  @map("updated_at")

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")

  @@map("verification")
}

enum OrderStatus {
  pending
  awaiting_payment
  paid
  fulfilled
  cancelled

  @@map("order_status")
}

enum PaymentStatus {
  pending
  completed
  failed
  cancelled

  @@map("payment_status")
}

enum PaymentMethod {
  chapa
  telebirr
  cod

  @@map("payment_method")
}

enum DeliveryMethod {
  standard
  pickup

  @@map("delivery_method")
}

model PickupLocation {
  id         String  @id @default(cuid())
  name       String
  line1      String  @map("line1")
  line2      String? @map("line2")
  city       String
  postalCode String  @map("postal_code")
  country    String  @default("Ethiopia")
  latitude   Decimal @db.Decimal(10, 7)
  longitude  Decimal @db.Decimal(10, 7)
  sortOrder  Int     @default(0) @map("sort_order")
  orders     Order[]

  @@index([sortOrder])
  @@map("pickup_locations")
}

enum ContentLocale {
  en
  am

  @@map("content_locale")
}

enum ShopStatus {
  pending
  active
  rejected
  suspended

  @@map("shop_status")
}

enum BusinessType {
  individual
  business

  @@map("business_type")
}

model Shop {
  id                       String         @id @default(cuid())
  slug                     String         @unique
  name                     String
  description              String?
  imageUrl                 String?        @map("image_url")
  /**
   * Wide hero image displayed on the public storefront page (`/shops/:slug`).
   */
  bannerImageUrl           String?        @map("banner_image_url")
  /**
   * Optional brand accent (hex like `#1f6feb`) used to tint storefront chrome
   * (CTAs, highlights). Stored as a 7-character string; validated at the edge.
   */
  accentColor              String?        @map("accent_color")
  ownerUserId              String?        @map("owner_user_id")
  owner                    User?          @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  status                   ShopStatus     @default(pending)
  contactEmail             String?        @map("contact_email")
  contactPhone             String?        @map("contact_phone")
  socialLinks              Json?          @map("social_links")
  shippingPolicy           String?        @map("shipping_policy") @db.Text
  returnsPolicy            String?        @map("returns_policy") @db.Text
  businessType             BusinessType?  @map("business_type")
  businessLegalName        String?        @map("business_legal_name")
  businessTaxId            String?        @map("business_tax_id")
  businessCity             String?        @map("business_city")
  businessSubcity          String?        @map("business_subcity")
  businessWoreda           String?        @map("business_woreda")
  businessKebele           String?        @map("business_kebele")
  businessHouseNumber      String?        @map("business_house_number")
  businessSpecificLocation String?        @map("business_specific_location")
  /**
   * Onboarding — Etsy-style checklist. Shop auto-activates when all required fields are set.
   */
  acceptedSellerPolicyAt   DateTime?      @map("accepted_seller_policy_at")
  payoutMethod             String?        @map("payout_method")
  payoutAccountName        String?        @map("payout_account_name")
  payoutAccountNumber      String?        @map("payout_account_number")
  payoutBankCode           String?        @map("payout_bank_code")
  onboardingCompletedAt    DateTime?      @map("onboarding_completed_at")
  /**
   * Denormalized: rolling avg seconds to first reply; updated on message events.
   */
  responseTimeAvgSeconds   Int?           @map("response_time_avg_seconds")
  /**
   * Denormalized: 0.0–1.0; fraction of first buyer messages with reply within 24h.
   */
  responseRate             Decimal?       @map("response_rate") @db.Decimal(4, 3)
  listings                 Listing[]
  conversations            Conversation[]
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")

  @@unique([ownerUserId])
  @@index([status])
  @@map("shops")
}

enum CategoryAttributeInputType {
  select
  text
  number
  boolean

  @@map("category_attribute_input_type")
}

model Category {
  id                   String                        @id @default(cuid())
  slug                 String                        @unique
  name                 String
  imageUrl             String                        @map("image_url")
  sortOrder            Int                           @default(0) @map("sort_order")
  listings             Listing[]
  translations         CategoryTranslation[]
  attributeDefinitions CategoryAttributeDefinition[]
  createdAt            DateTime                      @default(now()) @map("created_at")
  updatedAt            DateTime                      @updatedAt @map("updated_at")

  @@map("categories")
}

model CategoryAttributeDefinition {
  id            String                                   @id @default(cuid())
  categoryId    String                                   @map("category_id")
  category      Category                                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  key           String
  inputType     CategoryAttributeInputType               @map("input_type")
  sortOrder     Int                                      @default(0) @map("sort_order")
  isRequired    Boolean                                  @default(false) @map("is_required")
  allowedValues AttributeAllowedValue[]
  translations  CategoryAttributeDefinitionTranslation[]
  listingValues ListingAttributeValue[]

  @@unique([categoryId, key])
  @@index([categoryId])
  @@map("category_attribute_definitions")
}

model CategoryAttributeDefinitionTranslation {
  id           String                      @id @default(cuid())
  definitionId String                      @map("definition_id")
  definition   CategoryAttributeDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  locale       ContentLocale
  label        String

  @@unique([definitionId, locale])
  @@index([definitionId])
  @@map("category_attribute_definition_translations")
}

model AttributeAllowedValue {
  id            String                             @id @default(cuid())
  definitionId  String                             @map("definition_id")
  definition    CategoryAttributeDefinition        @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  key           String
  sortOrder     Int                                @default(0) @map("sort_order")
  translations  AttributeAllowedValueTranslation[]
  listingValues ListingAttributeValue[]

  @@unique([definitionId, key])
  @@index([definitionId])
  @@map("attribute_allowed_values")
}

model AttributeAllowedValueTranslation {
  id             String                @id @default(cuid())
  allowedValueId String                @map("allowed_value_id")
  allowedValue   AttributeAllowedValue @relation(fields: [allowedValueId], references: [id], onDelete: Cascade)
  locale         ContentLocale
  label          String

  @@unique([allowedValueId, locale])
  @@index([allowedValueId])
  @@map("attribute_allowed_value_translations")
}

model ListingAttributeValue {
  id             String                      @id @default(cuid())
  listingId      String                      @map("listing_id")
  listing        Listing                     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  definitionId   String                      @map("definition_id")
  definition     CategoryAttributeDefinition @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  allowedValueId String?                     @map("allowed_value_id")
  allowedValue   AttributeAllowedValue?      @relation(fields: [allowedValueId], references: [id], onDelete: Restrict)
  textValue      String?
  numberValue    Decimal?                    @db.Decimal(12, 4)
  booleanValue   Boolean?

  @@unique([listingId, definitionId])
  @@index([listingId])
  @@index([definitionId])
  @@index([allowedValueId])
  @@map("listing_attribute_values")
}

model CategoryTranslation {
  id         String        @id @default(cuid())
  categoryId String        @map("category_id")
  category   Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale     ContentLocale
  name       String

  @@unique([categoryId, locale])
  @@index([categoryId])
  @@map("category_translations")
}

model Tag {
  id           String           @id @default(cuid())
  slug         String           @unique
  name         String
  listingTags  ListingTag[]
  translations TagTranslation[]

  @@index([slug])
  @@map("tags")
}

model TagTranslation {
  id     String        @id @default(cuid())
  tagId  String        @map("tag_id")
  tag    Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)
  locale ContentLocale
  name   String

  @@unique([tagId, locale])
  @@index([tagId])
  @@map("tag_translations")
}

model Promotion {
  id           String                 @id @default(cuid())
  slug         String                 @unique
  title        String
  subtitle     String?
  badgeLabel   String                 @map("badge_label")
  startsAt     DateTime               @map("starts_at")
  endsAt       DateTime               @map("ends_at")
  heroImageUrl String?                @map("hero_image_url")
  sortOrder    Int                    @default(0) @map("sort_order")
  priority     Int                    @default(0)
  listings     PromotionListing[]
  translations PromotionTranslation[]
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  @@index([startsAt, endsAt])
  @@map("promotions")
}

model PromotionTranslation {
  id          String        @id @default(cuid())
  promotionId String        @map("promotion_id")
  promotion   Promotion     @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  locale      ContentLocale
  title       String
  subtitle    String?
  badgeLabel  String        @map("badge_label")

  @@unique([promotionId, locale])
  @@index([promotionId])
  @@map("promotion_translations")
}

model PromotionListing {
  id          String    @id @default(cuid())
  promotionId String    @map("promotion_id")
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  listingId   String    @map("listing_id")
  listing     Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sortOrder   Int       @default(0) @map("sort_order")

  @@unique([promotionId, listingId])
  @@index([promotionId])
  @@index([listingId])
  @@map("promotion_listings")
}

model Listing {
  id                String                  @id @default(cuid())
  slug              String                  @unique
  shopId            String                  @map("shop_id")
  shop              Shop                    @relation(fields: [shopId], references: [id], onDelete: Restrict)
  categoryId        String                  @map("category_id")
  category          Category                @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name              String
  description       String
  rating            Decimal                 @db.Decimal(3, 2)
  reviewCount       Int                     @map("review_count")
  featured          Boolean                 @default(false)
  isPublished       Boolean                 @default(false) @map("is_published")
  images            ListingImage[]
  variants          ListingVariant[]
  favorites         Favorite[]
  listingTags       ListingTag[]
  promotionListings PromotionListing[]
  translations      ListingTranslation[]
  ratings           ListingRating[]
  attributeValues   ListingAttributeValue[]
  orderItems        OrderItem[]
  conversations     Conversation[]
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([shopId])
  @@map("listings")
}

model ListingRating {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String   @map("listing_id")
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  stars     Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, listingId])
  @@index([listingId])
  @@map("listing_ratings")
}

model ListingTranslation {
  id          String        @id @default(cuid())
  listingId   String        @map("listing_id")
  listing     Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  locale      ContentLocale
  name        String
  description String

  @@unique([listingId, locale])
  @@index([listingId])
  @@map("listing_translations")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String   @map("listing_id")
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("favorites")
}

model ListingTag {
  listingId String  @map("listing_id")
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tagId     String  @map("tag_id")
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([listingId, tagId])
  @@map("listing_tags")
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String  @map("listing_id")
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int     @default(0) @map("sort_order")

  @@index([listingId])
  @@map("listing_images")
}

model ListingVariant {
  id             String                      @id @default(cuid())
  listingId      String                      @map("listing_id")
  listing        Listing                     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sku            String?                     @unique
  label          String
  colorHex       String?                     @map("color_hex")
  price          Decimal                     @db.Decimal(10, 2)
  compareAtPrice Decimal?                    @map("compare_at_price") @db.Decimal(10, 2)
  stock          Int
  cartItems      CartItem[]
  translations   ListingVariantTranslation[]

  @@index([listingId])
  @@map("listing_variants")
}

model ListingVariantTranslation {
  id        String         @id @default(cuid())
  variantId String         @map("variant_id")
  variant   ListingVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  locale    ContentLocale
  label     String

  @@unique([variantId, locale])
  @@index([variantId])
  @@map("listing_variant_translations")
}

model Cart {
  id               String     @id @default(cuid())
  userId           String?    @unique @map("user_id")
  user             User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousToken   String?    @unique @map("anonymous_token")
  items            CartItem[]
  /**
   * Last applied promo code (denormalized for cart summary); validated on checkout.
   */
  appliedPromoCode String?    @map("applied_promo_code")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@map("carts")
}

model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountPercent Int?      @map("discount_percent")
  discountAmount  Decimal?  @map("discount_amount") @db.Decimal(10, 2)
  minSubtotal     Decimal?  @map("min_subtotal") @db.Decimal(10, 2)
  maxRedemptions  Int?      @map("max_redemptions")
  perUserLimit    Int?      @map("per_user_limit")
  redemptions     Int       @default(0)
  validFrom       DateTime? @map("valid_from")
  validUntil      DateTime? @map("valid_until")
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([code])
  @@map("promo_codes")
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String         @map("cart_id")
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String         @map("variant_id")
  variant   ListingVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int

  @@unique([cartId, variantId])
  @@index([variantId])
  @@map("cart_items")
}

model Order {
  id                       String          @id @default(cuid())
  userId                   String          @map("user_id")
  user                     User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  status                   OrderStatus     @default(pending)
  subtotal                 Decimal         @db.Decimal(10, 2)
  shipping                 Decimal         @db.Decimal(10, 2)
  tax                      Decimal         @db.Decimal(10, 2)
  total                    Decimal         @db.Decimal(10, 2)
  deliveryMethod           DeliveryMethod  @default(standard) @map("delivery_method")
  pickupLocationId         String?         @map("pickup_location_id")
  pickupLocation           PickupLocation? @relation(fields: [pickupLocationId], references: [id], onDelete: Restrict)
  shippingCity             String          @map("shipping_city")
  shippingSubcity          String          @map("shipping_subcity")
  shippingWoreda           String          @map("shipping_woreda")
  shippingKebele           String          @map("shipping_kebele")
  shippingSpecificLocation String          @map("shipping_specific_location")
  items                    OrderItem[]
  payment                  Payment?
  /**
   * Idempotency key for checkout dedupe (userId + cart snapshot hash).
   */
  idempotencyKey           String?         @map("idempotency_key")
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")

  @@index([userId])
  @@index([idempotencyKey])
  @@map("orders")
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String   @map("order_id")
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listingId    String?  @map("listing_id")
  listing      Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  listingName  String   @map("listing_name")
  variantLabel String?  @map("variant_label")
  unitPrice    Decimal  @map("unit_price") @db.Decimal(10, 2)
  quantity     Int
  imageUrl     String   @map("image_url")

  @@index([orderId])
  @@index([listingId])
  @@map("order_items")
}

model Payment {
  id            String         @id @default(cuid())
  orderId       String         @unique @map("order_id")
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  txRef         String         @unique @map("tx_ref")
  chapaRef      String?        @map("chapa_ref")
  amount        Decimal        @db.Decimal(10, 2)
  currency      String         @default("ETB")
  status        PaymentStatus  @default(pending)
  paymentMethod PaymentMethod? @map("payment_method")
  chapaResponse Json?          @map("chapa_response")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([txRef])
  @@index([orderId])
  @@map("payments")
}

enum ConversationOutcome {
  open
  purchased
  no_response
  price_too_high
  changed_mind
  other

  @@map("conversation_outcome")
}

enum MessageKind {
  text
  system
  intent
  quick_action
  agreement_nudge

  @@map("message_kind")
}

model Conversation {
  id             String                         @id @default(cuid())
  buyerUserId    String                         @map("buyer_user_id")
  buyer          User                           @relation("ConversationBuyer", fields: [buyerUserId], references: [id], onDelete: Cascade)
  sellerShopId   String                         @map("seller_shop_id")
  shop           Shop                           @relation(fields: [sellerShopId], references: [id], onDelete: Restrict)
  listingId      String                         @map("listing_id")
  listing        Listing                        @relation(fields: [listingId], references: [id], onDelete: Restrict)
  lastMessageAt  DateTime                       @default(now()) @map("last_message_at")
  outcome        ConversationOutcome            @default(open) @map("outcome")
  outcomeAskedAt DateTime?                      @map("outcome_asked_at")
  closedAt       DateTime?                      @map("closed_at")
  messages       Message[]
  readStates     ConversationParticipantState[]
  createdAt      DateTime                       @default(now()) @map("created_at")

  @@unique([buyerUserId, listingId])
  @@index([sellerShopId, lastMessageAt])
  @@index([buyerUserId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String                         @id @default(cuid())
  conversationId String                         @map("conversation_id")
  conversation   Conversation                   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUserId   String                         @map("sender_user_id")
  sender         User                           @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  kind           MessageKind                    @default(text)
  body           String                         @db.Text
  meta           Json?
  createdAt      DateTime                       @default(now()) @map("created_at")
  readStates     ConversationParticipantState[] @relation("LastReadMessage")

  @@index([conversationId, createdAt])
  @@map("messages")
}

model ConversationParticipantState {
  conversationId    String       @map("conversation_id")
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId            String       @map("user_id")
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessageId String?      @map("last_read_message_id")
  lastReadMessage   Message?     @relation("LastReadMessage", fields: [lastReadMessageId], references: [id], onDelete: SetNull)

  @@id([conversationId, userId])
  @@index([userId])
  @@map("conversation_participant_states")
}
