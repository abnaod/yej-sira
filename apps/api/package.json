{
  "name": "@ys/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=es2022 --outfile=dist/index.js --sourcemap --external:dotenv --external:@prisma/client --external:@prisma/adapter-pg --external:pg --external:@hono/node-server --external:hono --external:better-auth --external:better-auth-telegram --external:zod --external:@sentry/node --external:sharp",
    "start": "node --env-file=../../.env dist/index.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test src/**/*.test.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "@ys/db": "workspace:*",
    "@ys/intl": "workspace:*",
    "better-auth": "catalog:",
    "better-auth-telegram": "^1.5.0",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "pg": "catalog:",
    "sharp": "^0.34.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@ys/tsconfig": "workspace:*",
    "esbuild": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
