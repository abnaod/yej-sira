# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/yej_sira?schema=public"

# Docker Compose — must match the user, password, and database name in DATABASE_URL above.
# Used to configure the postgres service and the API DATABASE_URL inside the stack (host `postgres`).
POSTGRES_USER="user"
POSTGRES_PASSWORD="password"
POSTGRES_DB="yej_sira"
# Optional: full URL for the API container only (overrides POSTGRES_* construction). Use when your
# password has characters that break compose interpolation — set host to `postgres`, not `localhost`.
# DOCKER_DATABASE_URL="postgresql://user:password@postgres:5432/yej_sira?schema=public"

# Better Auth (API) — basePath is /api/auth; BETTER_AUTH_URL must be this API origin
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3001"

# API server
PORT=3001

# CORS (browser origin for cookies / better-auth)
CORS_ORIGIN="http://localhost:3000"

# Web app: must match BETTER_AUTH_URL origin; client calls {VITE_API_URL}/api/auth
VITE_API_URL="http://localhost:3001"

# Web SSR only (runtime). In Docker Compose, set this to the API service URL so server-side
# fetches do not use localhost (which is the web container). Omit for local dev.
# SERVER_API_URL="http://api:3001"

# Web origin for payment return URLs, email links etc.
PUBLIC_WEB_URL="http://localhost:3000"

# Google OAuth (optional). Use these exact names — the API does not read VITE_GOOGLE_*.
# In Google Cloud Console → Credentials → your OAuth client → Authorized redirect URIs,
# add every origin you use in dev (hostname must match the API URL the browser calls):
#   http://localhost:3001/api/auth/callback/google
#   http://127.0.0.1:3001/api/auth/callback/google
# Never put GOOGLE_CLIENT_SECRET in a VITE_ variable (it would ship to the browser).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Chapa Payment (required for checkout)
# Get your keys from https://dashboard.chapa.co
# Use CHASECK_TEST-xxxx for testing, CHASECK-xxxx for production.
CHAPA_SECRET_KEY="CHASECK_TEST-xxxxxxxxxxxxxxxx"
# Secret hash from Chapa dashboard (Settings > Webhooks) for verifying webhook payloads.
# REQUIRED in production.
CHAPA_WEBHOOK_SECRET="your-random-webhook-secret-hash"
# Optional: override the API base URL (defaults to https://api.chapa.co)
# CHAPA_BASE_URL="https://api.chapa.co"

# Flat delivery fee (ETB) for standard shipping; store pickup is always free.
STANDARD_DELIVERY_FEE_ETB=150

# Transactional email (Resend). If RESEND_API_KEY is empty, emails are logged instead.
RESEND_API_KEY=""
EMAIL_FROM="noreply@yej-sira.local"
EMAIL_FROM_NAME="Yej-sira"

# Require users to verify their email before signing in (enable in production)
REQUIRE_EMAIL_VERIFICATION=false

# Error tracking (optional)
SENTRY_DSN=""
VITE_SENTRY_DSN=""

# Object storage for user uploads (Cloudflare R2 or any S3-compatible service).
# Leaving these empty falls back to local disk storage for development only.
S3_ENDPOINT=""
S3_BUCKET=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Public URL prefix for uploaded objects (e.g. https://cdn.yej-sira.com).
# When unset, stored URLs use /static/uploads/... served by the API.
CDN_BASE_URL=""
